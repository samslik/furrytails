<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kontakt - Furry Tails Fotografie</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <%- include("navbar") %>

  <main>
    <section class="contact-hero">
      <div class="container">
        <div class="contact-hero-content">
          <div class="contact-info-box">
            <div class="info-box-content">
              <h2>Lassen Sie uns gemeinsam etwas Schönes schaffen</h2>
              <p>Haben Sie Fragen oder sind Sie bereit zu buchen? Ich freue mich, von Ihnen zu hören</p>

              <div class="contact-details">
                <div class="contact-detail-item">
                  <img src="/gallery/mail white.png" alt="Email" width="24" height="24">
                  <a href="mailto:hello@furrytails.com">hello@furrytails.com</a>
                </div>
                <div class="contact-detail-item">
                  <img src="/gallery/phone white.png" alt="Phone" width="24" height="24">
                  <a href="tel:+1234567890">+1 (234) 567-890</a>
                </div>
                <div class="contact-detail-item">
                  <img src="/gallery/house white.png" alt="Location" width="24" height="24">
                  <p>Studio zu Hause in Berlin Prenzlauer Berg</p>
                </div>
              </div>
            </div>
            <div class="info-box-image">
              <img src="/gallery/Contact1.jpg" alt="Pet portrait" class="contact-pet-img">
            </div>
          </div>

          <div class="contact-form-box">
            <h3>EINE NACHRICHT SENDEN</h3>
            <form id="contactForm" class="contact-form">
              <div class="form-row">
                <div class="form-group">
                  <input type="text" id="name" name="name" placeholder="Ihr Name" required>
                </div>
                <div class="form-group">
                  <input type="email" id="email" name="email" placeholder="E-Mail-Adresse" required>
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <input type="tel" id="phone" name="phone" placeholder="Telefonnummer">
                </div>
                <div class="form-group">
                  <input type="tel" id="phone2" name="phone2" placeholder="Telefonnummer">
                </div>
              </div>

              <div class="form-group">
                <textarea id="message" name="message" placeholder="Ihre Nachricht" rows="6" required></textarea>
              </div>

              <button type="submit" class="contact-submit-btn">NACHRICHT SENDEN →</button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <section class="contact-social">
      <div class="container">
        <div class="social-content">
          <div class="social-icon">
            <img src="/gallery/camera.png" alt="Instagram" width="48" height="48">
          </div>
          <div class="social-text">
            <h2>Bleiben Sie in Kontakt</h2>
            <p>Wenn Sie neugierig auf meine letzten Projekte sind, folgen Sie mir auf Instagram</p>
          </div>
          <a href="https://instagram.com" class="social-link">@furrytails_photography</a>
          <div class="social-image">
            <img src="/gallery/pink.jpeg" alt="Pet portrait" class="social-pet-img">
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <div class="footer-logo">
            <img src="/gallery/logo.jpeg" alt="Logo" width="30" height="30">
            <span>Haustierfotografie</span>
          </div>
          <p>Die Freude und Persönlichkeit Ihrer liebsten Haustiere einfangen.</p>
        </div>
        <div class="footer-col">
          <h4>SCHNELLLINKS</h4>
          <ul>
            <li><a href="/<%= lang %>/gallery">Galerie</a></li>
            <li><a href="/<%= lang %>/how-it-works">Sitzungen</a></li>
            <li><a href="/<%= lang %>/prices">Preise</a></li>
            <li><a href="/<%= lang %>/about">Über Uns</a></li>
            <li><a href="/<%= lang %>/contact">Kontakt</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>BLEIBEN SIE IN KONTAKT</h4>
          <ul>
            <li><a href="https://instagram.com">Instagram</a></li>
            <li><a href="tel:+1234567890">(123) 456-7890</a></li>
            <li><a href="mailto:hello@furrytails.com">E-Mail</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <a href="/<%= lang %>/contact" class="footer-cta">JETZT BUCHEN</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Furry Tails Haustierfotografie. Alle Rechte vorbehalten.</p>
      </div>
    </div>
  </footer>

  <script>
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('nav-links');

    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('active');
      navLinks.style.display = navLinks.style.display === 'flex' ? 'none' : 'flex';
    });

    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        hamburger.classList.remove('active');
        navLinks.style.display = 'none';
      });
    });

    document.getElementById('contactForm').addEventListener('submit', function(e) {
      e.preventDefault();
      alert('Danke, dass Sie sich an mich gewandt haben! Ich werde mich bald bei Ihnen melden.');
      this.reset();
    });
  </script>
</body>
</html>
