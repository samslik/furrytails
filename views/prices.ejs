  <main>
    <!-- Hero Section -->
    <section class="prices-hero">
      <div class="container">
        <div class="prices-hero-content">
          <div class="prices-hero-image">
            <img src="/gallery/brown.jpeg" alt="Pet">
          </div>
          <div class="prices-hero-text">
            <h1>Simple sessions.<br>No overthinking</h1>
            <p class="hero-body">A relaxed in-home studio experience focused on your pet - with clear, straightforward pricing.</p>
            <p class="hero-secondary">You don't need a perfectly trained dog. We take things as they come</p>
            <div class="hero-cta">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>
              <span>It's not about perfect poses. It's about your pet, as they are</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Cards Section -->
    <section class="prices-section">
      <div class="container">
        <h2 class="section-title">CHOOSE THE SESSION THAT FITS YOU</h2>
        <div class="pricing-cards-grid">
          <!-- Basic Session -->
          <div class="pricing-card pricing-card-basic">
            <div class="card-price-section">
              <h4 class="card-name">Mini Session</h4>
              <p class="card-tagline">Short and simple</p>
              <p class="card-description">A quicker session focused on a few strong portraits, perfect for one pet</p>
              <h3 class="card-price">€150</h3>
            </div>
            <div class="card-content">
              <ul class="card-features">
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                  ~60 minutes
                </li>
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-paw-print"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg>
                  1 pet
                </li>
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square"><rect width="18" height="18" x="3" y="3" rx="2"/></svg>
                  1 background
                </li>
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-image"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                  3 digital images
                </li>
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-image"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                  1 print 20x30cm
                </li>
              </ul>
            </div>
          </div>

          <!-- Standard Session -->
          <div class="pricing-card pricing-card-standard">
            <div class="card-price-section">
              <h4 class="card-name">Standard Session</h4>
              <p class="card-tagline">The one most people choose</p>
              <p class="card-description">A relaxed session with enough time to settle in and get a good variety of the portraits</p>
              <h3 class="card-price">€230</h3>
            </div>
            <div class="card-content">
              <ul class="card-features">
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
