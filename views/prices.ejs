    <!-- Additional Info Section -->
    <section class="prices-add-info">
      <div class="container">
        <div class="add-info-wrapper">
          <div class="add-info-box add-info-pink">
            <div class="add-info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a11 11 0 0 1 0 22 11 11 0 0 1 0-22z"/></svg>
