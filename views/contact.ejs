<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact - Furry Tails Photography</title>
  <link rel="stylesheet" href="/styles.css">
  <%- include('head-scripts') %>
</head>
<body>
  <%- include("navbar") %>

  <main>
    <section class="contact-hero">
      <div class="container">
        <div class="contact-hero-content">
          <div class="contact-info-box">
            <div class="info-box-content">
              <h2>Let's create something beautiful together.</h2>
              <p>Have questions or ready to book? I'd love to hear from you</p>

              <div class="contact-details">
                <div class="contact-detail-item">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail-icon lucide-mail"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"/><rect x="2" y="4" width="20" height="16" rx="2"/></svg>
                  <a href="mailto:hello@furry-tails.de">hello@furry-tails.de</a>
                </div>
                <div class="contact-detail-item">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  <p>In-home Studio in Berlin Prenzlauer Berg</p>
                </div>
              </div>
            </div>
            <div class="info-box-image">
              <img src="/gallery/Contact1.jpg" alt="Pet portrait" class="contact-pet-img">
            </div>
          </div>

          <div class="contact-form-box">
            <h3>SEND A MESSAGE</h3>
            <form id="contactForm" class="contact-form">
              <div class="form-row">
                <div class="form-group">
                  <input type="text" id="name" name="name" placeholder="Your Name" required>
                </div>
                <div class="form-group">
                  <input type="email" id="email" name="email" placeholder="Email Address" required>
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <input type="tel" id="phone" name="phone" placeholder="Phone Number">
                </div>
              </div>

              <div class="form-group">
                <textarea id="message" name="message" placeholder="Your Message" rows="6" required></textarea>
              </div>

              <button type="submit" class="contact-submit-btn">SEND MESSAGE →</button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <section class="contact-social">
      <div class="container">
        <div class="social-content">
          <div class="social-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-camera-icon lucide-camera"><path d="M13.997 4a2 2 0 0 1 1.76 1.05l.486.9A2 2 0 0 0 18.003 7H20a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h1.997a2 2 0 0 0 1.759-1.048l.489-.904A2 2 0 0 1 10.004 4z"/><circle cx="12" cy="13" r="3"/></svg>
          </div>
          <div class="social-text">
            <h2>Let's stay in touch.</h2>
            <p>If you're curious about my latest projects, follow me on Instagram.</p>
            <a href="https://www.instagram.com/hundefotografberlin/" class="social-link">
              Instagram
              <img src="/gallery/Instagram.png" alt="Instagram" class="social-icon">
            </a>
          </div>
          <div class="social-image">
            <img src="/gallery/contact-insta.jpg" alt="Pet portrait" class="social-pet-img">
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('footer') %>

  <script>
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('nav-links');

    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('active');
      navLinks.style.display = navLinks.style.display === 'flex' ? 'none' : 'flex';
    });

    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        hamburger.classList.remove('active');
        navLinks.style.display = 'none';
      });
    });

    document.getElementById('contactForm').addEventListener('submit', async function(e) {
      e.preventDefault();

      const formData = {
        name: document.getElementById('name').value,
        email: document.getElementById('email').value,
        phone: document.getElementById('phone').value,
        message: document.getElementById('message').value
      };

      try {
        const response = await fetch('https://contact.furry-tails.de', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });

        if (response.ok) {
          alert('Thank you for reaching out! I\'ll get back to you soon.');
          this.reset();
        } else {
          alert('Error sending email. Please try again.');
        }
      } catch (error) {
        alert('Error: ' + error.message);
      }
    });
  </script>
</body>
</html>
