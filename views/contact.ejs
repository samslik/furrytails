<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact - Furry Tails Photography</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <div class="logo">
        <a href="/">
          <img src="/gallery/logo.jpeg" alt="Logo" width="40" height="40">
          Pet Photography
        </a>
      </div>
      <button class="hamburger" id="hamburger">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <ul class="nav-links" id="nav-links">
        <li><a href="/gallery">GALLERY</a></li>
        <li><a href="/how-it-works">SESSIONS</a></li>
        <li><a href="/prices">PRICES</a></li>
        <li><a href="/about">ABOUT</a></li>
        <li><a href="/contact">CONTACT</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <section class="contact-hero">
      <div class="container">
        <div class="contact-hero-content">
          <div class="contact-info-box">
            <div class="info-box-content">
              <h2>Let's create something beautiful together</h2>
              <p>Have questions or ready to book? I'd love to hear from you</p>

              <div class="contact-details">
                <div class="contact-detail-item">
                  <img src="/gallery/mail white.png" alt="Email" width="24" height="24">
                  <a href="mailto:hello@furrytails.com">hello@furrytails.com</a>
                </div>
                <div class="contact-detail-item">
                  <img src="/gallery/phone white.png" alt="Phone" width="24" height="24">
                  <a href="tel:+1234567890">+1 (234) 567-890</a>
                </div>
                <div class="contact-detail-item">
                  <img src="/gallery/house white.png" alt="Location" width="24" height="24">
                  <p>In-home Studio in Berlin Prenzlauer Berg</p>
                </div>
              </div>
            </div>
            <div class="info-box-image">
              <img src="/gallery/turqouse.jpeg" alt="Pet portrait" class="contact-pet-img">
            </div>
          </div>

          <div class="contact-form-box">
            <h3>SEND A MESSAGE</h3>
            <form id="contactForm" class="contact-form">
              <div class="form-row">
                <div class="form-group">
                  <input type="text" id="name" name="name" placeholder="Your Name" required>
                </div>
                <div class="form-group">
                  <input type="email" id="email" name="email" placeholder="Email Address" required>
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <input type="tel" id="phone" name="phone" placeholder="Phone Number">
                </div>
                <div class="form-group">
                  <input type="tel" id="phone2" name="phone2" placeholder="Phone Number">
                </div>
              </div>

              <div class="form-group">
                <textarea id="message" name="message" placeholder="Your Message" rows="6" required></textarea>
              </div>

              <button type="submit" class="contact-submit-btn">SEND MESSAGE →</button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <section class="contact-social">
      <div class="container">
        <div class="social-content">
          <div class="social-icon">
            <img src="/gallery/camera.png" alt="Instagram" width="48" height="48">
          </div>
          <div class="social-text">
            <h2>Let's stay in touch</h2>
            <p>If you're curious about my latest projects, follow me on Instagram</p>
          </div>
          <a href="https://instagram.com" class="social-link">@furrytails_photography</a>
          <div class="social-image">
            <img src="/gallery/pink.jpeg" alt="Pet portrait" class="social-pet-img">
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <div class="footer-logo">
            <img src="/gallery/logo.jpeg" alt="Logo" width="30" height="30">
            <span>Pet Photography</span>
          </div>
          <p>Capturing the joy and personality of your beloved pets.</p>
        </div>
        <div class="footer-col">
          <h4>QUICK LINKS</h4>
          <ul>
            <li><a href="/gallery">Gallery</a></li>
            <li><a href="/how-it-works">Sessions</a></li>
            <li><a href="/prices">Prices</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>LET'S CONNECT</h4>
          <ul>
            <li><a href="https://instagram.com">Instagram</a></li>
            <li><a href="tel:+1234567890">(123) 456-7890</a></li>
            <li><a href="mailto:hello@furrytails.com">Email</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <a href="/contact" class="footer-cta">BOOK A SESSION</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Furry Tails Pet Photography. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('nav-links');

    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('active');
      navLinks.style.display = navLinks.style.display === 'flex' ? 'none' : 'flex';
    });

    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        hamburger.classList.remove('active');
        navLinks.style.display = 'none';
      });
    });

    document.getElementById('contactForm').addEventListener('submit', function(e) {
      e.preventDefault();
      alert('Thank you for reaching out! I\'ll get back to you soon.');
      this.reset();
    });
  </script>
</body>
</html>
