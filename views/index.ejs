<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Furry Tails Photography - Pet Photographer</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <div class="logo">
        <a href="/">
          <img src="/gallery/logo.jpeg" alt="Logo" width="40" height="40">
          Pet Photography
        </a>
      </div>
      <button class="hamburger" id="hamburger">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <ul class="nav-links" id="nav-links">
        <li><a href="/gallery">GALLERY</a></li>
        <li><a href="/how-it-works">SESSIONS</a></li>
        <li><a href="/prices">PRICES</a></li>
        <li><a href="/">VOUCHERS</a></li>
        <li><a href="/about">ABOUT</a></li>
        <li><a href="/contact">CONTACT</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <section class="hero-grid">
      <div class="container-fluid">
        <div class="hero-cards">
          <!-- Left Column -->
          <div class="hero-column hero-column-left">
            <!-- Card 1: Teal -->
            <div class="hero-card card-teal">
              <div class="card-text-container">
                <h2><span>Extraordinary studio pet portraits.</span><span>Brag-worthy. Timeless.</span></h2>
                <p>Treat your pet to a professional studio session filled with play, treats and perfect results that highlight their unique character.</p>
                <div class="card-buttons">
                  <a href="/contact" class="card-btn">BOOK A SESSION →</a>
                  <a href="/gallery" class="card-btn">VIEW GALLERY →</a>
                </div>
              </div>
              <div class="card-image">
                <img src="/gallery/turqouse.jpeg" alt="Pet portrait" class="pet-img">
              </div>
            </div>

            <!-- Card 3: Light Blue -->
            <div class="hero-card card-lightblue">
              <div class="card-text-container">
                <h2>Relaxed sessions, at your pet's pace.</h2>
                <p>Whether your dog is energetic or a bit unsure, the session adapts to them.</p>
                <a href="/how-it-works" class="card-btn">HOW IT WORKS →</a>
              </div>
              <div class="card-image">
                <img src="/gallery/blue.jpeg" alt="Pet portrait" class="pet-img">
              </div>
            </div>
          </div>

          <!-- Right Column -->
          <div class="hero-column hero-column-right">
            <!-- Card 2: Pink -->
            <div class="hero-card card-pink">
              <div class="card-text-container">
                <h2><span>Clean setup. Perfect light.</span><span>No distractions.</span></h2>
                <p>Carefully chosen backdrops, soft direction, and attention to detail — so the focus stays where it should be.</p>
              </div>
              <div class="card-pink-bottom">
                <p class="subtle-text">Not sure which session fit? Start here.</p>
                <a href="/prices" class="card-btn">SESSIONS / PROCESS →</a>
              </div>
              <div class="card-image">
                <img src="/gallery/pink.jpeg" alt="Pet portrait" class="pet-img">
              </div>
            </div>

            <!-- Card 4: Brown -->
            <div class="hero-card card-brown">
              <div class="card-text-container">
                <h2>READY WHEN YOU ARE</h2>
                <p>If you're thinking about a session, you can book directly or get in touch first.</p>
                <a href="/contact" class="card-btn">CONTACT →</a>
              </div>
              <div class="card-image">
                <img src="/gallery/brown.jpeg" alt="Pet portrait" class="pet-img">
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="about-section">
      <div class="container">
        <div class="about-wrapper">
          <div class="about-text">
            <h3>HI, I'M ANNA.</h3>
            <h2>PET PHOTOGRAPHER, DOG LOVER</h2>
            <p>I create vibrant, authentic portraits for pets and people who love them. Most of the time, the best photos happen in between moments. That's what I look for during a session.</p>
            <a href="/about" class="btn-link">MORE ABOUT ME →</a>
          </div>

          <div class="about-features">
            <div class="feature">
              <div class="feature-icon">
                <img src="/gallery/camera.png" alt="Camera icon" width="40" height="40">
              </div>
              <h4>NATURAL & AUTHENTIC</h4>
              <p>No stiff poses</p>
            </div>
            <div class="feature">
              <div class="feature-icon">
                <img src="/gallery/heart.png" alt="Heart icon" width="40" height="40">
              </div>
              <h4>EXPERIENCE MATTERS</h4>
              <p>A relaxed, joyful session</p>
            </div>
            <div class="feature">
              <div class="feature-icon">
                <img src="/gallery/star.png" alt="Star icon" width="40" height="40">
              </div>
              <h4>ART YOU'LL LOVE</h4>
              <p>Beautiful, timeless</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <div class="footer-logo">
            <img src="/gallery/logo.jpeg" alt="Logo" width="30" height="30">
            <span>Pet Photography</span>
          </div>
          <p>Capturing the joy and personality of your beloved pets.</p>
        </div>
        <div class="footer-col">
          <h4>QUICK LINKS</h4>
          <ul>
            <li><a href="/gallery">Gallery</a></li>
            <li><a href="/how-it-works">Sessions</a></li>
            <li><a href="/prices">Prices</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>LET'S CONNECT</h4>
          <ul>
            <li><a href="https://instagram.com">Instagram</a></li>
            <li><a href="tel:+1234567890">(123) 456-7890</a></li>
            <li><a href="mailto:hello@furrytails.com">Email</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <a href="/contact" class="footer-cta">BOOK A SESSION</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Furry Tails Pet Photography. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('nav-links');

    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('active');
      navLinks.style.display = navLinks.style.display === 'flex' ? 'none' : 'flex';
    });

    // Close menu when a link is clicked
    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        hamburger.classList.remove('active');
        navLinks.style.display = 'none';
      });
    });
  </script>
</body>
</html>
