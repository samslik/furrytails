<!-- Zeeg popup script start -->
<link href="https://assets.zeeg.me/embed.min.css" rel="stylesheet" />
<script type="text/javascript" src="https://assets.zeeg.me/embed.min.js"></script>
<!-- Zeeg popup script end -->

<nav class="navbar">
  <div class="container">
    <div class="logo">
      <a href="/<%= lang %>/">
        <img src="/gallery/logo.jpeg" alt="Logo" width="40" height="40">
        <span><% if (lang === 'de') { %>Tierfotografie<% } else { %>Pet Photography<% } %><br>in Berlin</span>
      </a>
    </div>
    <button class="hamburger" id="hamburger">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul class="nav-links" id="nav-links">
      <li><a href="" class="zeeg-link" onclick="Zeeg.initPopupWidget({ url: 'https://zeeg.me/samslik/pet-photography-session', utm: { 'source': null, 'medium': null, 'campaign': null, 'content': null, 'term': null }});return false;"><%= t.nav.bookSession %></a></li>
      <li><a href="/<%= lang %>/gallery/"><%= t.nav.gallery %></a></li>
      <li><a href="/<%= lang %>/how-it-works/"><%= t.nav.sessions %></a></li>
      <li><a href="/<%= lang %>/prices/"><%= t.nav.prices %></a></li>
      <li><a href="/<%= lang %>/about/"><%= t.nav.about %></a></li>
      <li><a href="/<%= lang %>/contact/"><%= t.nav.contact %></a></li>
      <li class="lang-switcher">
        <% if (lang === 'en') { %>
          <a href="/<%= currentPath ? 'de/' + currentPath : 'de/' %>">🇩🇪 DE</a>
        <% } else { %>
          <a href="/<%= currentPath ? 'en/' + currentPath : 'en/' %>">🇬🇧 EN</a>
        <% } %>
      </li>
    </ul>
  </div>
</nav>

<script src="/app.js"></script>
