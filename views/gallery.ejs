<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gallery - Furry Tails Photography</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <div class="logo">
        <a href="/">Furry Tails Photography</a>
      </div>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/how-it-works">How It Works</a></li>
        <li><a href="/about">About Me</a></li>
        <li><a href="/prices">Prices</a></li>
        <li><a href="/gallery">Gallery</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Gallery</h1>
        <p>Beautiful moments captured with love</p>
      </div>
    </section>

    <section class="gallery-section">
      <div class="container">
        <div class="gallery-grid">
          <div class="gallery-item">
            <div class="placeholder-image" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"></div>
            <p>Golden Retriever Portrait</p>
          </div>
          <div class="gallery-item">
            <div class="placeholder-image" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);"></div>
            <p>Playful Kittens</p>
          </div>
          <div class="gallery-item">
            <div class="placeholder-image" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);"></div>
            <p>Curious Cat</p>
          </div>
          <div class="gallery-item">
            <div class="placeholder-image" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);"></div>
            <p>Energetic Husky</p>
          </div>
          <div class="gallery-item">
            <div class="placeholder-image" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);"></div>
            <p>Lazy Bulldog</p>
          </div>
          <div class="gallery-item">
            <div class="placeholder-image" style="background: linear-gradient(135deg, #30cfd0 0%, #330867 100%);"></div>
            <p>Nature Walk</p>
          </div>
        </div>

        <div class="gallery-cta">
          <p>Love what you see? Let's capture your pet's beauty!</p>
          <a href="/contact" class="cta-button">Book Your Session</a>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <p>&copy; 2026 Furry Tails Photography. All rights reserved.</p>
      <p><a href="/contact">Get in touch</a></p>
    </div>
  </footer>
</body>
</html>
